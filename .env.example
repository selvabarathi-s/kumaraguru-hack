# Root / general
NODE_ENV=development

# Frontend (Vite) — copy to frontend/.env.local for local dev
VITE_API_BASE_URL=http://localhost:5000/api
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
VITE_MAP_ATTRIBUTION=&copy; OpenStreetMap contributors

# Backend — copy to backend/.env
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=ewaste_schema
# PORT=5000
# FLASK_URL=http://localhost:5001
# CV_URL=http://localhost:5002
# LOG_LEVEL=info
# ML_REQUEST_TIMEOUT_MS=60000

# ML service (Flask) — port 5001 by default in app.py

# CV service (PyTorch/Flask) — port 5002 by default in cv-service/app.py
