DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ewaste_schema
PORT=5000
# Must match where Flask ml-service listens (default 5001). If you see ML errors, open
# http://localhost:5001/health in a browser — should show tabular_loaded: true after train.py
FLASK_URL=http://localhost:5001
LOG_LEVEL=info
ML_REQUEST_TIMEOUT_MS=60000
NODE_ENV=development
